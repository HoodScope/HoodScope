{
  "name": "hoodscope",
  "version": "0.1.0",
  "description": "AI-powered token security scanner for Robinhood Chain — CLEAR / REVIEW / FLAGGED assessments",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/HoodScope/HoodScope.git"
  },
  "homepage": "https://hoodscope.pro",
  "keywords": [
    "token-security",
    "honeypot",
    "robinhood-chain",
    "defi",
    "cli",
    "on-chain-intelligence"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "scan": "tsx scripts/scan.ts",
    "cli": "tsx cli/src/index.ts",
    "cli:build": "npm run build --prefix cli",
    "cli:install": "npm run cli:build && npm link --prefix cli",
    "install:agent": "node scripts/install-agent.mjs",
    "install:agent:skill": "node scripts/install-agent.mjs --skill",
    "github:check": "node scripts/github-preflight.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.54.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5"
  }
}
