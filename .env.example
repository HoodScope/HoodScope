# HoodScope — optional environment variables
# Copy to .env.local for local development

# GitHub Models API — enables AI-powered scan summaries
# Create at: https://github.com/settings/tokens (models:read scope)
# GITHUB_TOKEN=ghp_...

# Override Robinhood Chain RPC (optional)
# HOODSCOPE_RPC_URL=https://rpc.mainnet.chain.robinhood.com
